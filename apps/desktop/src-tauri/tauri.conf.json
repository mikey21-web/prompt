{
  "productName": "PromptForge",
  "version": "1.0.0",
  "identifier": "com.promptforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PromptForge",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "app"],
    "identifier": "com.promptforge.app",
    "icon": []
  },
  "updater": {
    "active": true,
    "endpoints": [
      "https://releases.promptforge.app/latest.json"
    ],
    "dialog": true,
    "pubkey": "dW3/IeTG2X7KscVlFkWhJTdoncbOO7zDMwc3W6m65o="
  }
}
